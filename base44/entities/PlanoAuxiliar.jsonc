{
  "name": "PlanoAuxiliar",
  "type": "object",
  "properties": {
    "nome": {
      "type": "string",
      "description": "Nome do plano auxiliar"
    },
    "marca": {
      "type": "string",
      "description": "Marca associada ao plano",
      "enum": [
        "DIMEP",
        "MADIS"
      ]
    },
    "ativo": {
      "type": "boolean",
      "default": true,
      "description": "Se o plano est\u00e1 ativo"
    }
  },
  "required": [
    "nome"
  ]
}