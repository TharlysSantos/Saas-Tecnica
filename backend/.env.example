# Servidor
PORT=3050
NODE_ENV=development

# Frontend (para CORS)
FRONTEND_URL=http://localhost:3051

# Vindi API
VINDI_API_KEY=sua_chave_aqui
VINDI_BASE_URL=https://sandbox-app.vindi.com.br/api/v1

# Base44 SDK (mesmas do frontend .env)
BASE44_APP_ID=seu_app_id
BASE44_APP_BASE_URL=https://seu-app.base44.com

# Segredo JWT (se implementar auth própria)
JWT_SECRET=troque_por_valor_seguro

# Notify API (acionada pelo CI/CD ao aprovar build)
NOTIFY_API_URL=
